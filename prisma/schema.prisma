generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  category  String
  date      DateTime
  readTime  String
  content   String   @db.Text
  imageUrl  String?
  author    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}

model CaseStudy {
  id           String   @id @default(cuid())
  slug         String   @unique
  company      String
  industry     String
  challenge    String   @db.Text
  intervention String   @db.Text
  metrics      Json
  imageUrl     String?
  createdAt    DateTime @default(now())

  @@map("case_studies")
}

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  initials String
  role     String
  shortBio String
  fullBio  String  @db.Text
  photoUrl String?
  linkedin String?
  order    Int     @default(0)

  @@map("team_members")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String
  quote     String   @db.Text
  photoUrl  String?
  rating    Int      @default(5)
  industry  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("testimonials")
}

model ClientLogo {
  id      String  @id @default(cuid())
  name    String
  logoUrl String
  url     String?
  order   Int     @default(0)

  @@map("client_logos")
}

model Candidate {
  id                String   @id @default(cuid())
  prenom            String
  nom               String
  email             String?
  phone             String?
  linkedin          String?
  date              DateTime?
  contrat           String?
  tjm               String?
  dispo             String?
  loc               String?
  remote            String?
  days              String?
  sector            String?
  notes             String?  @db.Text
  resumeText        String?  @db.Text
  scores            Json?
  forces            Json?
  risks             Json?
  // v17 — taxonomies multi-select
  profileTypes      Json?    // types de profils qu'il recrute (Sales/Tech/Product/...)
  companyTypes      Json?    // types de boîtes pour lesquelles il a travaillé (Startup seed/SaaS B2B/...)
  profileStyle      Json?    // style de personnalité (Sharp / Hunter / Architecte / ...)
  intelligenceTypes Json?    // types d'intelligence (analytique / émotionnelle / stratégique / ...)
  // v18 — nouvelle structure entretien
  openCddCdi        Boolean? // candidat ouvert à un CDD ou CDI ?
  qualifProfile     String?  // Généraliste / Sales / IT (étape 1 du chemin)
  qualifLevel       String?  // Junior / Mid / Senior / Expert (étape 2)
  qualifRecruitedTypes Json? // types de profils recrutés selon branche (étape 2)
  qualifContext     Json?    // précisions contextuelles (étape 3)
  intelligenceLevel String?  // Faible / Moyen / Fort / Exceptionnel
  motivationTypes   Json?    // Sharp / Hungry / Ambitieux / Calme posé / ...
  motivationLevel   String?  // Faible / Moyen / Fort / Exceptionnel
  sympathyTypes     Json?    // Chaleureux / Bienveillant / Direct cash / ...
  sympathyLevel     String?  // Faible / Moyen / Fort / Exceptionnel
  // v19 — langues parlées (liste d'objets { lang, level })
  languagesSpoken   Json?
  score             Int      @default(0)
  maxScore          Int      @default(0)
  pct               Int      @default(0)
  filled            Int      @default(0)
  hasCv             Boolean  @default(false)
  cvPath            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("candidates")
}
